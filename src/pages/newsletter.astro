---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>
  <!-- CONTENT GOES HERE-->
  <main class="max-w-4xl mx-auto px-4 py-16">
    <!-- Hero Section -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Join Our Pack
      </h1>
      <p class="text-xl text-gray-700 mb-2">
        Get Expert Dog Training Tips Delivered to Your Inbox
      </p>
      <p class="text-gray-600">
        Real-world strategies, behavior insights, and proven techniques from a
        certified professional trainer
      </p>
    </div>

    <!-- Two Column Layout -->
    <div class="grid md:grid-cols-2 gap-12 mb-16">
      <!-- Left Column - Benefits -->
      <div class="space-y-8">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            What You'll Receive
          </h2>

          <div class="space-y-6">
            <!-- Benefit 1 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <svg
                  class="w-6 h-6 text-yellow-500"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-2">
                  Weekly Training Tips
                </h3>
                <p class="text-gray-600">
                  Practical, actionable advice you can implement immediately
                  with your dog
                </p>
              </div>
            </div>

            <!-- Benefit 2 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <svg
                  class="w-6 h-6 text-yellow-500"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-2">
                  Behavior Insights
                </h3>
                <p class="text-gray-600">
                  Understand why your dog does what they do and how to address
                  common challenges
                </p>
              </div>
            </div>

            <!-- Benefit 3 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <svg
                  class="w-6 h-6 text-yellow-500"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-2">
                  Exclusive Content
                </h3>
                <p class="text-gray-600">
                  Access to training videos, guides, and resources not available
                  anywhere else
                </p>
              </div>
            </div>

            <!-- Benefit 4 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <svg
                  class="w-6 h-6 text-yellow-500"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-2">
                  Program Updates
                </h3>
                <p class="text-gray-600">
                  Early access to new training programs and special offers for
                  subscribers
                </p>
              </div>
            </div>

            <!-- Benefit 5 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <svg
                  class="w-6 h-6 text-yellow-500"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-2">
                  Success Stories
                </h3>
                <p class="text-gray-600">
                  Real transformations from real dogs and their dedicated owners
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Trust Indicators -->
        <div class="bg-gray-50 rounded-2xl p-6">
          <p class="text-sm text-gray-600 mb-4">
            <strong class="text-gray-900">Privacy Promise:</strong> We respect your
            inbox. No spam, no daily emails, and you can unsubscribe anytime with
            one click.
          </p>
          <p class="text-sm text-gray-600">
            Join <strong class="text-gray-900">500+</strong> dog owners who get our
            weekly insights
          </p>
        </div>
      </div>

      <!-- Right Column - Signup Form -->
      <div>
        <div
          id="newsletter-form"
          class="bg-gradient-to-br from-yellow-50 to-yellow-100 rounded-2xl p-8 shadow-lg border border-yellow-200"
        >
          <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">
            Start Your Journey Today
          </h2>

          <!-- Replace this form action with your actual email service provider -->
          <iframe
            data-tally-src="https://tally.so/embed/aQd6YW?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
            loading="lazy"
            width="100%"
            height="634"
            frameborder="0"
            marginheight="0"
            marginwidth="0"
            title="LLK9 News Letter"></iframe>
          <script>
            var d = document,
              w = "https://tally.so/widgets/embed.js",
              v = function () {
                "undefined" != typeof Tally
                  ? Tally.loadEmbeds()
                  : d
                      .querySelectorAll("iframe[data-tally-src]:not([src])")
                      .forEach(function (e) {
                        e.src = e.dataset.tallySrc;
                      });
              };
            if ("undefined" != typeof Tally) v();
            else if (d.querySelector('script[src="' + w + '"]') == null) {
              var s = d.createElement("script");
              ((s.src = w),
                (s.onload = v),
                (s.onerror = v),
                d.body.appendChild(s));
            }
          </script>
        </div>

        <!-- Social Proof -->
        <div class="mt-8 text-center">
          <p class="text-sm text-gray-600 italic">
            "These weekly emails have completely changed how I understand my
            reactive dog. The tips are practical and actually work!"
          </p>
          <p class="text-sm text-gray-700 font-semibold mt-2">
            — Sarah M., Martinsville
          </p>
        </div>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="mt-16 max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">
        Frequently Asked Questions
      </h2>

      <div class="space-y-4">
        <!-- FAQ 1 -->
        <details
          class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 group"
        >
          <summary
            class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center"
          >
            How often will I receive emails?
            <svg
              class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <p class="mt-4 text-gray-600">
            You'll receive one email per week, typically sent on Tuesday
            mornings. We respect your time and inbox — quality over quantity.
          </p>
        </details>

        <!-- FAQ 2 -->
        <details
          class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 group"
        >
          <summary
            class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center"
          >
            Is this newsletter free?
            <svg
              class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <p class="mt-4 text-gray-600">
            Yes, completely free. No hidden costs, no credit card required. Our
            newsletter is our way of sharing knowledge with the dog training
            community.
          </p>
        </details>

        <!-- FAQ 3 -->
        <details
          class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 group"
        >
          <summary
            class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center"
          >
            Can I unsubscribe anytime?
            <svg
              class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <p class="mt-4 text-gray-600">
            Absolutely. Every email includes a one-click unsubscribe link at the
            bottom. No questions asked, no hard feelings.
          </p>
        </details>

        <!-- FAQ 4 -->
        <details
          class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 group"
        >
          <summary
            class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center"
          >
            Will you share my email address?
            <svg
              class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <p class="mt-4 text-gray-600">
            Never. Your privacy is sacred. We will never sell, rent, or share
            your email address with anyone. Period.
          </p>
        </details>

        <!-- FAQ 5 -->
        <details
          class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 group"
        >
          <summary
            class="font-semibold text-gray-900 cursor-pointer list-none flex justify-between items-center"
          >
            What if I'm a beginner dog owner?
            <svg
              class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </summary>
          <p class="mt-4 text-gray-600">
            Perfect! Our content is designed for all experience levels. We break
            down complex concepts into simple, actionable steps anyone can
            follow.
          </p>
        </details>
      </div>
    </div>

    <!-- Final CTA -->
    <div
      class="mt-16 text-center p-8 rounded-2xl bg-gray-50 border border-gray-200"
    >
      <h2 class="text-2xl font-bold text-gray-900 mb-4">
        Ready to Transform Your Relationship with Your Dog?
      </h2>
      <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
        Join hundreds of dog owners who are building calmer, more confident
        companions through structure, communication, and real-world training
        strategies.
      </p>
      <a
        href="#newsletter-form"
        class="inline-block bg-yellow-500 text-white font-semibold px-8 py-4 rounded-full hover:bg-yellow-600 transition transform hover:scale-105 shadow-lg"
      >
        Subscribe to Our Newsletter
      </a>
    </div>
  </main>
</MainLayout>
