            }
          </script>

          <p class="text-sm text-purple-200 mt-6">
            We'll send the guide to your email immediately. No spam, no selling
            your info.
          </p>
        </div>

        <div class="mt-12">
          <p class="text-lg font-semibold mb-4">
            <strong>Need hands-Nn support?</strong>
          </p>
          <p class="text-purple-100 mb-6">
            Our Puppy Foundation Program provides live training, weekly
            check-ins, and personalized guidance for Martinsville & Surrounding
            Areas families.
          </p>
          <a
            href="https://leashlegacyk9.com/programs/puppy-starter/"
            class="inline-block bg-white text-purple-600 font-bold px-10 py-4 rounded-full hover:bg-gray-100 transition"
          >
            Learn About Our Puppy Program →
          </a>
        </div>
      </div>
    </section>

    <!-- FINAL SECTION -->
    <section class="py-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-gray-900 mb-8">
          Your Calm Puppy Starts Here
        </h2>
        <p class="text-xl text-gray-700 mb-8 leading-relaxed">
          The puppy stage goes fast. One moment they're an 8-week-old bundle in
          your arms. The next, they're a teenager testing your patience. <strong
            >The foundation work you do NOW determines the dog they become.</strong
          >
        </p>
        <p class="text-lg text-gray-700 italic mb-8">
          "Every puppy will have behavior problems unless you specifically
          prevent them. This guide shows you how."
        </p>
        <a
          href="#download"
          class="inline-block bg-yellow-500 hover:bg-yellow-600 text-gray-900 font-bold px-10 py-4 rounded-full text-lg transition transform hover:scale-105"
        >
          Download Your Free Guide Now
