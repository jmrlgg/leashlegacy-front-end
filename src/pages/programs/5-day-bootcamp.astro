---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout>
  <!-- MAIN CONTENT -->
  <main class="max-w-7xl mx-auto px-4 py-8">
    <!-- HERO SECTION -->
    <section class="mb-16">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <span
            class="text-purple-600 font-bold text-sm uppercase tracking-wider"
            >Programs</span
          >
          <h1
            class="text-5xl md:text-6xl font-bold text-gray-900 mt-2 mb-4 leading-tight"
          >
            5-Day Bootcamp
          </h1>
          <div class="flex justify-center gap-3 mb-6">
            <span class="tag">3-5 Days</span>
            <span class="tag">Foundation Training</span>
            <span class="tag">Drop-Off Available</span>
          </div>
          <p
            class="text-xl md:text-2xl text-gray-700 max-w-4xl mx-auto leading-relaxed"
          >
            Kickstart your dog's obedience journey with <strong
              >positive reinforcement</strong
            >, foundational skills, and gentle e-collar introduction. Perfect
            for dogs just starting out, this program builds <strong
              >confidence, engagement, and structure</strong
            >.
          </p>
          <p class="text-gray-600 mt-4">
            <strong>Serving Bassett & Southwest Virginia</strong> • <a
              href="tel:+12762292625"
              class="text-purple-600 hover:underline font-semibold"
              >(276) 229-2625</a
            >
          </p>
        </div>

        <!-- Quick CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
          <a
            href="#day-by-day"
            class="bg-purple-600 hover:bg-purple-700 text-white font-bold px-8 py-4 rounded-full text-lg transition transform hover:scale-105 text-center"
          >
            See Day-by-Day Details
          </a>
          <a
            href="https://leashlegacyk9.com/contact/"
            class="bg-gray-900 hover:bg-gray-800 text-white font-bold px-8 py-4 rounded-full text-lg border-2 border-gray-900 transition text-center"
          >
            Schedule a Consultation
          </a>
        </div>
      </div>
    </section>

    <!-- WHAT IS THIS PROGRAM -->
    <section class="mb-20 bg-white rounded-2xl shadow-xl p-8 md:p-12">
      <h2 class="text-4xl font-bold text-gray-900 mb-8 text-center">
        What Is the 5-Day Bootcamp?
      </h2>

      <div class="max-w-4xl mx-auto">
        <div
          class="bg-gradient-to-br from-purple-50 to-indigo-50 p-8 rounded-xl border-2 border-purple-200 mb-8"
        >
          <p class="text-lg text-gray-800 leading-relaxed mb-4">
            The <strong>5-Day Bootcamp</strong> (formerly called the Kickstarter Program)
            is a <strong>focused immersion program</strong> designed to establish
            foundational obedience, build engagement, and introduce calm communication
            through positive reinforcement.
          </p>
          <p class="text-lg text-gray-800 leading-relaxed">
            This is <strong>not a quick fix or magic solution</strong>. This is
            the <em>beginning</em> of a training relationship—a reset that gives you
            and your dog the tools, structure, and clarity needed to continue building
            together.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 mb-8">
          <div class="bg-green-50 border-l-4 border-green-500 p-6 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-3 text-lg">
              ✅ This Program IS:
            </h3>
            <ul class="space-y-2 text-gray-700">
              <li>• A structured obedience & behavior foundation</li>
              <li>• Real-world exposure done safely and intentionally</li>
              <li>• Clear communication training (not force-based)</li>
              <li>
                • Designed to support future adventures and training goals
              </li>
              <li>• Foundation for more advanced programs</li>
            </ul>
          </div>

          <div class="bg-red-50 border-l-4 border-red-500 p-6 rounded-lg">
            <h3 class="font-bold text-gray-900 mb-3 text-lg">
              ❌ This Program IS NOT:
            </h3>
            <ul class="space-y-2 text-gray-700">
              <li>• A full 6-week board & train</li>
              <li>• A shortcut to perfection</li>
              <li>• A replacement for handler follow-through</li>
              <li>• A punishment-based system</li>
              <li>• Appropriate for severe reactivity or aggression</li>
            </ul>
          </div>
        </div>

        <div
          class="bg-yellow-50 border-2 border-yellow-300 p-6 rounded-xl text-center"
        >
          <p class="text-lg font-semibold text-gray-900">
            <strong>Remember:</strong> Dogs don't fail programs. <span
              class="text-purple-700">Inconsistency does.</span
            >
          </p>
        </div>
      </div>
    </section>

    <!-- PROGRAM INCLUDES -->
    <section class="mb-20">
      <h2 class="text-4xl font-bold text-gray-900 mb-12 text-center">
        What's Included in Your Bootcamp
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div
          class="feature-card bg-white p-6 rounded-xl shadow-md border-t-4 border-purple-500"
        >
          <div class="text-4xl mb-4">📅</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">3-5 Day Training</h3>
          <p class="text-gray-700 text-sm">
            Daily drop-off sessions Monday through Friday. Choose 3-day or 5-day
            option based on your dog's needs.
          </p>
        </div>

        <div
          class="feature-card bg-white p-6 rounded-xl shadow-md border-t-4 border-blue-500"
        >
          <div class="text-4xl mb-4">🎓</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Handler Transfer</h3>
          <p class="text-gray-700 text-sm">
            Live demonstration and hands-on coaching on final day. You'll
            practice with your dog under professional guidance.
          </p>
        </div>

        <div
          class="feature-card bg-white p-6 rounded-xl shadow-md border-t-4 border-green-500"
        >
          <div class="text-4xl mb-4">📖</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Take-Home Guide</h3>
          <p class="text-gray-700 text-sm">
            Custom training plan with clear instructions for continued progress
            at home. Simple, actionable homework.
          </p>
        </div>

        <div
          class="feature-card bg-white p-6 rounded-xl shadow-md border-t-4 border-yellow-500"
        >
          <div class="text-4xl mb-4">🔄</div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">
            Follow-Up Session
          </h3>
          <p class="text-gray-700 text-sm">
            30-minute evaluation within 7 days to troubleshoot, adjust
            techniques, and ensure you're on track.
          </p>
        </div>
      </div>

      <div class="mt-8 bg-purple-50 border-2 border-purple-200 p-6 rounded-xl">
        <h3 class="text-xl font-bold text-gray-900 mb-3 text-center">
          Plus: E-Collar Conditioning (If Appropriate)
        </h3>
        <p class="text-gray-700 text-center max-w-3xl mx-auto">
          E-collar introduction is <strong
            >optional and only used when appropriate</strong
          > for your dog's temperament. When introduced, it's done carefully at the
          lowest functional level and always paired with positive reinforcement. <strong
            >Our goal is clear communication—not correction.</strong
          >
        </p>
      </div>
    </section>

    <!-- DAY-BY-DAY BREAKDOWN -->
    <section id="day-by-day" class="mb-20">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          Day-by-Day Journey
        </h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Here's exactly what happens each day. <strong
            >Every dog learns at their own pace</strong
          >, so we adjust based on progress, temperament, and response to
          training.
        </p>
      </div>

      <div class="space-y-6">
        <!-- Day 1 -->
        <div class="day-card bg-white p-8 rounded-xl shadow-md">
          <div class="flex items-start gap-4">
            <div
              class="bg-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold flex-shrink-0"
            >
              1
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Day 1 — Assessment & Engagement
              </h3>
              <p class="text-gray-700 mb-4">
                <em
                  >Getting to know your dog and building the foundation for
                  clear communication.</em
                >
              </p>
              <div class="bg-purple-50 p-4 rounded-lg mb-4">
                <h4 class="font-bold text-purple-900 mb-2">Focus Areas:</h4>
                <p class="text-sm text-purple-800">
                  Understanding the dog • Building trust • Reading body language
                  • Establishing communication
                </p>
              </div>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Temperament and personality evaluation</strong> — Understanding
                    how your dog communicates and learns</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Intro to clicker/reward system</strong> — Teaching the
                    marker system for clear timing</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Name recognition & eye contact</strong> — Making your
                    name the best predictor of good things</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Start Sit and Down</strong> — Foundation obedience with
                    leash guidance and rewards</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>E-collar fitting and response testing</strong> — (If
                    appropriate) Lowest level only, no pressure, just observation</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Heel position introduction</strong> — Teaching your dog
                    where "with you" means</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Loose leash walking basics</strong> — With turns, marking
                    good decisions, building awareness</span
                  >
                </li>
              </ul>
              <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
                <p class="text-sm font-semibold text-green-900">
                  <strong>Day 1 Goal:</strong> Create trust, establish communication,
                  and identify your dog's learning style.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Day 2 -->
        <div class="day-card bg-white p-8 rounded-xl shadow-md">
          <div class="flex items-start gap-4">
            <div
              class="bg-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold flex-shrink-0"
            >
              2
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Day 2 — Leash Basics & Communication
              </h3>
              <p class="text-gray-700 mb-4">
                <em
                  >Building on yesterday's foundation with refined leash work
                  and clear communication.</em
                >
              </p>
              <div class="bg-purple-50 p-4 rounded-lg mb-4">
                <h4 class="font-bold text-purple-900 mb-2">Focus Areas:</h4>
                <p class="text-sm text-purple-800">
                  Movement • Guidance • Calm leadership • Reward timing • Early
                  recall
                </p>
              </div>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Refining leash walking</strong> — Adding turns, direction
                    changes, and awareness</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Marking and reward timing</strong> — Teaching your dog
                    that calm, focused behavior earns clarity</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Automatic sits</strong> — When handler stops, dog sits
                    without being asked</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Begin 'Come' recall</strong> — With leash and reward,
                    teaching that coming when called is always a good decision</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>E-collar adjustment</strong> — (If in use) Adjust based
                    on dog's feedback from Day 1</span
                  >
                </li>
              </ul>
              <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
                <p class="text-sm font-semibold text-green-900">
                  <strong>Day 2 Goal:</strong> Teach the dog how to move <em
                    >with</em
                  > a human instead of against them.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Day 3 -->
        <div class="day-card bg-white p-8 rounded-xl shadow-md">
          <div class="flex items-start gap-4">
            <div
              class="bg-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold flex-shrink-0"
            >
              3
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Day 3 — Structure & Duration
              </h3>
              <p class="text-gray-700 mb-4">
                <em
                  >Building reliability and impulse control through duration
                  work and distractions.</em
                >
              </p>
              <div class="bg-purple-50 p-4 rounded-lg mb-4">
                <h4 class="font-bold text-purple-900 mb-2">Focus Areas:</h4>
                <p class="text-sm text-purple-800">
                  Reliability • Impulse control • Duration • Small distractions
                  • Nervous system regulation
                </p>
              </div>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Increase duration</strong> — Longer holds on Sit and
                    Down, teaching patience</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Introduce Place command</strong> — Mat or cot work, teaching
                    your dog to settle on a designated spot</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Add small distractions</strong> — Toys, noise, movement—teaching
                    calm decision-making</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Continue leash walking</strong> — With automatic sits
                    and better focus</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Maintaining criteria</strong> — Reinforcing calm holds
                    without pressure or rushing</span
                  >
                </li>
              </ul>
              <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
                <p class="text-sm font-semibold text-green-900">
                  <strong>Day 3 Goal:</strong> Teach the dog to hold behaviors calmly—not
                  rush through them.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Day 4 (Optional) -->
        <div
          class="day-card bg-white p-8 rounded-xl shadow-md border-2 border-blue-200"
        >
          <div class="flex items-start gap-4">
            <div
              class="bg-blue-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold flex-shrink-0"
            >
              4
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Day 4 (Optional) — Reinforcement & Challenges
              </h3>
              <p class="text-gray-700 mb-4">
                <em
                  >Building confidence and starting to proof skills in
                  real-world scenarios.</em
                >
              </p>
              <div class="bg-blue-50 p-4 rounded-lg mb-4">
                <h4 class="font-bold text-blue-900 mb-2">Focus Areas:</h4>
                <p class="text-sm text-blue-800">
                  Confidence building • Real-world exposure • Outdoor recall •
                  Environmental challenges
                </p>
              </div>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-2">
                  <span class="text-blue-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Confidence-building obstacles</strong> — Steps, different
                    surfaces, light environmental challenges</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Start long-line recall outdoors</strong> — Giving your
                    dog more freedom and distance to practice coming when called</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Real-world scenarios</strong> — Working obedience in
                    slightly harder, more distracting environments</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Building reliability</strong> — Practicing skills in
                    new contexts and conditions</span
                  >
                </li>
              </ul>
              <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
                <p class="text-sm font-semibold text-green-900">
                  <strong>Day 4 Goal:</strong> Build reliability in slightly harder
                  scenarios and prepare for real-world adventures.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Day 5 (Optional) -->
        <div
          class="day-card bg-white p-8 rounded-xl shadow-md border-2 border-green-200"
        >
          <div class="flex items-start gap-4">
            <div
              class="bg-green-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold flex-shrink-0"
            >
              5
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Day 5 (Optional) — Owner Transfer & Practice
              </h3>
              <p class="text-gray-700 mb-4">
                <em
                  >The most important day: You learn to work with your trained
                  dog.</em
                >
              </p>
              <div class="bg-green-50 p-4 rounded-lg mb-4">
                <h4 class="font-bold text-green-900 mb-2">Focus Areas:</h4>
                <p class="text-sm text-green-800">
                  Handler education • Live transfer • Troubleshooting • Homework
                  plan • Confidence building
                </p>
              </div>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-2">
                  <span class="text-green-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Live demonstration</strong> — Watch every command demonstrated
                    clearly</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-green-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Hands-on coaching</strong> — You practice with your dog
                    under professional guidance</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-green-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Review custom training plan</strong> — Clear homework
                    and at-home structure recommendations</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-green-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Provide resources</strong> — Take-home guide and tools
                    for continued success</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-green-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Build your confidence</strong> — Learn proper timing,
                    body language, and troubleshooting</span
                  >
                </li>
              </ul>
              <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
                <p class="text-sm font-semibold text-green-900">
                  <strong>Day 5 Goal:</strong> You leave with confidence, a clear
                  plan, and the ability to maintain what we've built.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="mt-12 p-8 bg-gradient-to-r from-purple-50 to-blue-50 border-2 border-purple-300 rounded-xl"
      >
        <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">
          Choose Your Duration
        </h3>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white p-6 rounded-xl border-2 border-gray-200">
            <h4 class="font-bold text-gray-900 mb-2 text-lg">3-Day Bootcamp</h4>
            <p class="text-gray-700 text-sm mb-3">
              Days 1-3: Foundation training, engagement, basic obedience, leash
              manners
            </p>
            <p class="text-xs text-gray-600 italic">
              Best for: Dogs needing basic structure and leash skills
            </p>
          </div>
          <div class="bg-white p-6 rounded-xl border-2 border-purple-300">
            <h4 class="font-bold text-gray-900 mb-2 text-lg">
              5-Day Bootcamp (Recommended)
            </h4>
            <p class="text-gray-700 text-sm mb-3">
              Days 1-5: Everything above PLUS confidence work, outdoor recall,
              and full handler transfer
            </p>
            <p class="text-xs text-gray-600 italic">
              Best for: Dogs needing comprehensive foundation and confident
              handler transition
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHO IS THIS FOR -->
    <section
      class="mb-20 bg-gradient-to-br from-blue-50 to-indigo-100 py-16 px-4 rounded-2xl"
    >
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-gray-900 mb-12 text-center">
          Perfect For
        </h2>

        <div class="grid md:grid-cols-2 gap-6 mb-8">
          <div class="bg-white p-6 rounded-xl shadow-md flex items-start gap-4">
            <span class="text-3xl">🐕</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Dogs 5+ Months Old</h3>
              <p class="text-gray-700 text-sm">
                Young dogs or adolescents needing structure and foundational
                obedience
              </p>
            </div>
          </div>

          <div class="bg-white p-6 rounded-xl shadow-md flex items-start gap-4">
            <span class="text-3xl">🏠</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">New Adoptees</h3>
              <p class="text-gray-700 text-sm">
                Recently adopted dogs needing clarity, routine, and
                communication
              </p>
            </div>
          </div>

          <div class="bg-white p-6 rounded-xl shadow-md flex items-start gap-4">
            <span class="text-3xl">🚶</span>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">Leash Manners Issues</h3>
              <p class="text-gray-700 text-sm">
