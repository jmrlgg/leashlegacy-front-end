---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout>
  <!-- MAIN CONTENT -->
  <main class="max-w-7xl mx-auto px-4 py-8">
    <!-- HERO SECTION -->
    <section class="mb-16">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-8">
          <span
            class="text-yellow-600 font-bold text-sm uppercase tracking-wider"
            >Programs</span
          >
          <h1
            class="text-5xl md:text-6xl font-bold text-gray-900 mt-2 mb-4 leading-tight"
          >
            Off-Leash Freedom Program
          </h1>
          <div class="flex justify-center gap-3 mb-6">
            <span class="tag">E-Collar Optional</span>
            <span class="tag">6 Weeks</span>
            <span class="tag">Board & Train or Private</span>
          </div>
          <p
            class="text-xl md:text-2xl text-gray-700 max-w-4xl mx-auto leading-relaxed"
          >
            A <strong>6-week progression</strong> that builds calm, reliable off-leash
            control through positive reinforcement. The e-collar is <strong
              >100% opt-in</strong
            > and, if used, is paired with food, toys, and praise—never punishment.
          </p>
          <p class="text-gray-600 mt-4">
            <strong>Serving Bassett & Southwest Virginia</strong> • <a
              href="tel:+12762292625"
              class="text-yellow-600 hover:underline font-semibold"
              >(276) 229-2625</a
            >
          </p>
        </div>

        <!-- Quick CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
          <a
            href="#week-by-week"
            class="bg-yellow-500 hover:bg-yellow-600 text-gray-900 font-bold px-8 py-4 rounded-full text-lg transition transform hover:scale-105 text-center"
          >
            See Week-by-Week Details
          </a>
          <a
            href="https://leashlegacyk9.com/contact/"
            class="bg-gray-900 hover:bg-gray-800 text-white font-bold px-8 py-4 rounded-full text-lg border-2 border-gray-900 transition text-center"
          >
            Schedule a Consultation
          </a>
        </div>
      </div>
    </section>

    <!-- PROGRAM OVERVIEW -->
    <section class="mb-20 bg-white rounded-2xl shadow-xl p-8 md:p-12">
      <h2 class="text-4xl font-bold text-gray-900 mb-8 text-center">
        Two Ways to Transform Your Dog
      </h2>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Board & Train Option -->
        <div
          class="feature-card bg-gradient-to-br from-orange-50 to-yellow-50 p-8 rounded-xl border-2 border-yellow-200"
        >
          <div class="flex items-center gap-3 mb-4">
            <div
              class="bg-yellow-500 text-white w-12 h-12 rounded-full flex items-center justify-center text-2xl font-bold"
            >
              🏠
            </div>
            <h3 class="text-2xl font-bold text-gray-900">
              6-Week Board & Train
            </h3>
          </div>
          <p class="text-gray-700 mb-6">
            Your dog lives with us for total transformation—then we hand you the
            keys for real-world success.
          </p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-green-600 flex-shrink-0 mt-1"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-800"
                ><strong>Full immersion training</strong> in distraction-rich environments</span
              >
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-green-600 flex-shrink-0 mt-1"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-800"
                ><strong
                  >Daily structured training, rest, and decompression</strong
                ></span
              >
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-green-600 flex-shrink-0 mt-1"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-800"
                ><strong
                  >Perfect for reactivity, off-leash goals, or total resets</strong
                ></span
              >
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-green-600 flex-shrink-0 mt-1"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-800"
                ><strong>Weekly progress updates</strong> with photos/videos</span
              >
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-green-600 flex-shrink-0 mt-1"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-800"
                ><strong>Multiple handler transfer sessions</strong> at your real-world
                locations</span
              >
            </li>
          </ul>
          <p class="text-sm text-gray-600 italic">
            Best for: Busy owners, serious behavior issues, or dogs needing
            intensive work away from home distractions.
          </p>
        </div>

        <!-- Private Lessons Option -->
        <div
          class="feature-card bg-gradient-to-br from-blue-50 to-indigo-50 p-8 rounded-xl border-2 border-blue-200"
        >
          <div class="flex items-center gap-3 mb-4">
            <div
              class="bg-blue-500 text-white w-12 h-12 rounded-full flex items-center justify-center text-2xl font-bold"
            >
              📚
            </div>
            <h3 class="text-2xl font-bold text-gray-900">
              6-Week Private Lessons
            </h3>
          </div>
          <p class="text-gray-700 mb-6">
            Your dog stays home. We work together weekly with customized
            training plans and ongoing support.
          </p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-green-600 flex-shrink-0 mt-1"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-800"
                ><strong>Weekly 60-min sessions</strong> at your home or training
                locations</span
              >
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-green-600 flex-shrink-0 mt-1"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-800"
                ><strong>Hands-on coaching</strong> for you AND your dog</span
              >
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-green-600 flex-shrink-0 mt-1"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-800"
                ><strong>Customized homework plans</strong> based on your lifestyle</span
              >
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-green-600 flex-shrink-0 mt-1"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-800"
                ><strong>Text/email support</strong> between sessions for questions</span
              >
            </li>
            <li class="flex items-start gap-2">
              <svg
                class="w-5 h-5 text-green-600 flex-shrink-0 mt-1"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-800"
                ><strong>Lifetime follow-up guidance</strong> after graduation</span
              >
            </li>
          </ul>
          <p class="text-sm text-gray-600 italic">
            Best for: Owners who want to be deeply involved in training and have
            time for daily practice.
          </p>
        </div>
      </div>

      <div class="mt-8 p-6 bg-yellow-50 border-2 border-yellow-300 rounded-xl">
        <p class="text-gray-900 text-center">
          <strong>Both programs follow the same proven curriculum.</strong> The difference
          is whether your dog trains with us full-time or you work together at home
          with weekly coaching.
        </p>
      </div>
    </section>

    <!-- PROGRAM HIGHLIGHTS -->
    <section class="mb-20">
      <h2 class="text-4xl font-bold text-gray-900 mb-12 text-center">
        What Makes This Program Different
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- E-Collar Optional -->
        <div
          class="feature-card bg-white p-8 rounded-xl shadow-md border-t-4 border-green-500"
        >
          <div class="text-5xl mb-4">✅</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            E-Collar is 100% Optional
          </h3>
          <p class="text-gray-700 mb-4">
            <strong>No pressure to use an e-collar.</strong> Many dogs succeed with
            reward-based training and long-line work alone. If you choose to use one,
            we show you how to do it humanely.
          </p>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>• Correct fit and lowest effective level only</li>
            <li>• Always paired with rewards—never punishment</li>
            <li>• Functions like a "tap on the shoulder"</li>
            <li>• You decide if it's right for your dog</li>
          </ul>
        </div>

        <!-- Real-World Training -->
        <div
          class="feature-card bg-white p-8 rounded-xl shadow-md border-t-4 border-blue-500"
        >
          <div class="text-5xl mb-4">🌍</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            Real-World Reliability
          </h3>
          <p class="text-gray-700 mb-4">
            We don't just train in perfect conditions. We proof skills where you
            actually need them: trails, parks, busy neighborhoods, around other
            dogs and distractions.
          </p>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>• Trails, parks, storefronts, sidewalks</li>
            <li>• Distance × Duration × Distractions layered progressively</li>
            <li>• Neutrality around people, dogs, and surprises</li>
            <li>• Skills that hold when it matters most</li>
          </ul>
        </div>

        <!-- Lifetime Support -->
        <div
          class="feature-card bg-white p-8 rounded-xl shadow-md border-t-4 border-purple-500"
        >
          <div class="text-5xl mb-4">🤝</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            Lifetime Guidance
          </h3>
          <p class="text-gray-700 mb-4">
            Training doesn't end at graduation. You get lifetime text/email
            support for questions, setbacks, and continued growth.
          </p>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>• Text/email check-ins anytime</li>
            <li>• Troubleshooting support for life</li>
            <li>• Home setup and maintenance plans</li>
            <li>• We're in this for the long haul</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- WEEK-BY-WEEK JOURNEY -->
    <section id="week-by-week" class="mb-20">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          The 6-Week Journey
        </h2>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Here's exactly what happens each week, whether your dog boards with us
          or trains with you at home through private lessons.
        </p>
      </div>

      <div class="space-y-6">
        <!-- Week 1 -->
        <div class="week-card bg-white p-8 rounded-xl shadow-md">
          <div class="flex items-start gap-4">
            <div
              class="bg-yellow-500 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold flex-shrink-0"
            >
              1
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Week 1 — Reset & Relationship
              </h3>
              <p class="text-gray-700 mb-4">
                <em
                  >Building trust, engagement, and the foundation for everything
                  that follows.</em
                >
              </p>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Decompression & routine</strong> — Creating calm through
                    structure and predictability</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Marker timing & engagement games</strong> — Making training
                    fun and clear</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Foundation obedience</strong> — Sit, Down, Place, structured
                    leash walks</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>E-collar introduction (if chosen)</strong> — Proper fit,
                    finding working level, pairing with rewards</span
                  >
                </li>
              </ul>
              <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
                <p class="text-sm font-semibold text-green-900">
                  <strong>Week 1 Goal:</strong> Your dog is settled, engaged, and
                  understands the training game.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Week 2 -->
        <div class="week-card bg-white p-8 rounded-xl shadow-md">
          <div class="flex items-start gap-4">
            <div
              class="bg-yellow-500 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold flex-shrink-0"
            >
              2
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Week 2 — Skills & Structure
              </h3>
              <p class="text-gray-700 mb-4">
                <em
                  >Adding duration, building confidence, and refining
                  communication.</em
                >
              </p>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Duration work</strong> — Longer holds on Sit/Down/Place</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Calm handling</strong> — Collar grabs, paw touches, vet-prep
                    exercises</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Confidence building</strong> — New surfaces, sights,
                    and sounds</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>E-collar pairing (if chosen)</strong> — Gentle use on
                    recall and heel for clarity</span
                  >
                </li>
              </ul>
              <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
                <p class="text-sm font-semibold text-green-900">
                  <strong>Week 2 Goal:</strong> Reliable basics with calmer, more
                  thoughtful daily behavior.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Week 3 -->
        <div class="week-card bg-white p-8 rounded-xl shadow-md">
          <div class="flex items-start gap-4">
            <div
              class="bg-yellow-500 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold flex-shrink-0"
            >
              3
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Week 3 — Recall & Real-Life Manners
              </h3>
              <p class="text-gray-700 mb-4">
                <em
                  >Building bombproof recall and teaching everyday household
                  manners.</em
                >
              </p>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Long-line recall work</strong> — "Come" with increasing
                    distractions</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Heel position & auto check-ins</strong> — Engagement
                    during walks</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Doorway manners</strong> — No rushing through doors</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Polite greetings & settle routines</strong> — Calm around
                    people and in the home</span
                  >
                </li>
              </ul>
              <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
                <p class="text-sm font-semibold text-green-900">
                  <strong>Week 3 Goal:</strong> Recall is taking root; manners show
                  up reliably at home.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Week 4 -->
        <div class="week-card bg-white p-8 rounded-xl shadow-md">
          <div class="flex items-start gap-4">
            <div
              class="bg-yellow-500 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold flex-shrink-0"
            >
              4
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Week 4 — Distraction Proofing & Confidence
              </h3>
              <p class="text-gray-700 mb-4">
                <em
                  >Testing skills in real-world chaos and building unshakeable
                  confidence.</em
                >
              </p>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Field trips</strong> — Storefronts, parks, busy sidewalks,
                    neighborhoods</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>The 3 D's layered</strong> — Distance × Duration × Distractions
                    progressively increased</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Early off-leash reps</strong> — In safe, fenced spaces</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Confidence reps</strong> — Keeping your dog thoughtful,
                    not frantic</span
                  >
                </li>
              </ul>
              <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
                <p class="text-sm font-semibold text-green-900">
                  <strong>Week 4 Goal:</strong> Skills hold under real-world pressure
                  and distractions.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Week 5 -->
        <div class="week-card bg-white p-8 rounded-xl shadow-md">
          <div class="flex items-start gap-4">
            <div
              class="bg-yellow-500 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold flex-shrink-0"
            >
              5
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">
                Week 5 — Off-Leash Reliability + Handler Coaching
              </h3>
              <p class="text-gray-700 mb-4">
                <em>Advanced work and your first hands-on transfer session.</em>
              </p>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Advanced recalls</strong> — Distance, distractions, real-world
                    scenarios</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Neutrality training</strong> — Passing dogs and people
                    calmly</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>Off-leash heel and recall</strong> — Where safe and appropriate</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-yellow-600 font-bold">•</span>
                  <span class="text-gray-800"
                    ><strong>First transfer session</strong> — You practice with live
                    coaching from us</span
                  >
                </li>
              </ul>
