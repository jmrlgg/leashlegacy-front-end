---
import FooterInfo from "./FooterInfo.astro";
import { programs } from "../data/programs";

const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white py-12 px-4">
  <div class="max-w-6xl mx-auto">
    <!-- Centered Logo -->
    <div class="flex justify-center mb-8">
      <img
        src="https://leashlegacyk9.com/imgs/leashlegacyk9.webp"
        alt="Professional dog training services specializing in board & train programs, behavior modification, and reactivity rehabilitation in Martinsville, VA."
        class="w-24 h-auto"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- Footer Grid Content -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-center md:text-left">
      <!-- Brand summary -->
      <div>
        <h3 class="text-xl font-bold text-yellow-500 mb-4">
          Leash Legacy K9 Training
        </h3>
        <p class="text-gray-300">
          Helping Virginia dog owners build calm, confident companions through
          balanced, humane training.
        </p>

        <div class="mt-4 space-y-2 text-gray-400">
          <p class="flex items-start justify-center md:justify-start gap-2">
            <!-- Map Pin -->
            <svg
              class="w-5 h-5 flex-none text-yellow-400"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 2.25c-4.28 0-7.75 3.47-7.75 7.75 0 5.48 6.5 11.04 7.03 11.5a1.2 1.2 0 0 0 1.44 0c.53-.46 7.03-6.02 7.03-11.5 0-4.28-3.47-7.75-7.75-7.75Zm0 10.25a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5Z"
              ></path>
            </svg>
            <span>Bassett, Virginia</span>
          </p>

          <p class="flex items-center justify-center md:justify-start gap-2">
            <!-- Phone -->
            <svg
              class="w-5 h-5 flex-none text-yellow-400"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l1.98-1.98a1.5 1.5 0 0 1 1.54-.36c1.68.55 3.49.85 5.27.85.83 0 1.5.67 1.5 1.5V21a1.5 1.5 0 0 1-1.5 1.5C10.3 22.5 1.5 13.7 1.5 3A1.5 1.5 0 0 1 3 1.5h2.61c.83 0 1.5.67 1.5 1.5 0 1.78.3 3.59.85 5.27.15.52.02 1.08-.36 1.54l-1.98 1.98Z"
              ></path>
            </svg>
            <a
              href="tel:+12762292625"
              class="text-yellow-400 hover:underline font-semibold"
              aria-label="Call (276) 229-2625"
            >
              (276) 229-2625
            </a>
          </p>
        </div>
      </div>

      <!-- Programs column (DATA-DRIVEN) -->
      <div id="footer-programs">
        <h4 class="text-lg font-semibold text-yellow-500 mb-4">Programs</h4>
        <ul class="space-y-2">
          {
            programs.map((p) => (
              <li>
                <a href={p.href} class="hover:text-yellow-400 transition">
                  {p.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Locations column -->
      <div id="footer-locations">
        <h4 class="text-lg font-semibold text-yellow-500 mb-4">
          Locations we Serve
        </h4>
        <ul class="space-y-2">
          <li>Collinsville, VA</li>
          <li>Martinsville, VA</li>
          <li>Rocky Mount, VA</li>
          <li>Boones Mill, VA</li>
          <li>Roanoke, VA</li>
        </ul>
      </div>

      <!-- Footer Icons (keep your existing block as-is) -->
      <div id="footer-icons">
        <!-- components/FooterIcons.html -->
        <!-- components/FooterIcons.html -->
        <div class="mt-5">
          <h5 class="text-sm uppercase tracking-wide text-gray-400 mb-2">
            Connect
          </h5>

          <ul
            class="flex items-center justify-center md:justify-start space-x-4"
          >
            <!-- Email -->
            <li class="shrink-0">
              <a
                href="mailto:leashlegacyk9@gmail.com?subject=Inquiry%20from%20Website"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-gray-700/60 hover:border-yellow-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-yellow-400 text-gray-300 hover:text-yellow-300"
                aria-label="Email Leash Legacy K9 Training"
                target="_blank"
                rel="noopener"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                  <path d="M3 7l9 6 9-6"></path>
                </svg>
              </a>
            </li>

            <!-- Facebook -->
            <li class="shrink-0">
              <a
                href="https://facebook.com/leashlegacyk9?utm_source=website&utm_medium=visit-social&utm_campaign=facebook&utm_id=social-links"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-gray-700/60 hover:border-yellow-400 focus-visible:ring-2 focus-visible:ring-yellow-400 text-gray-300 hover:text-yellow-300"
                aria-label="Facebook"
                target="_blank"
                rel="noopener"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M18 2h-2.5A4.5 4.5 0 0 0 11 6.5V9H9v4h2v8h4v-8h2.9l.6-4H15V6.6c0-.35.28-.63.63-.63H18V2z"
                  ></path>
                </svg>
              </a>
            </li>

            <!-- Instagram -->
            <li class="shrink-0">
              <a
                href="https://instagram.com/leashlegacyk9?utm_source=website&utm_medium=visit-social&utm_campaign=instagram&utm_id=social-links"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-gray-700/60 hover:border-yellow-400 focus-visible:ring-2 focus-visible:ring-yellow-400 text-gray-300 hover:text-yellow-300"
                aria-label="Instagram"
                target="_blank"
                rel="noopener"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
                  <circle cx="12" cy="12" r="3.5"></circle>
                  <circle cx="17.2" cy="6.8" r="1"></circle>
                </svg>
              </a>
            </li>

            <!-- YouTube -->
            <li class="shrink-0">
              <a
                href="https://youtube.com/@leashlegacyk9?utm_source=website&utm_medium=visit-social&utm_campaign=youtube&utm_id=social-links"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-gray-700/60 hover:border-yellow-400 focus-visible:ring-2 focus-visible:ring-yellow-400 text-gray-300 hover:text-yellow-300"
                aria-label="YouTube"
                target="_blank"
                rel="noopener"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="2" y="6" width="20" height="12" rx="3"></rect>
                  <polygon points="10 9 15 12 10 15 10 9"></polygon>
                </svg>
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Bottom Strip (NO JS) -->
      <div
        class="mt-12 border-t border-gray-700 pt-6 text-center text-sm text-gray-400"
      >
        © {year}{" "}
        <a href="https://leashlegacyk9.com" class="hover:text-yellow-400">
          Leash Legacy K9 Training LLC
        </a>{" "}
        — Calm Leadership, Clear Communication, Real-World Reliability.
        <br />
        <a href="/privacy" class="hover:text-yellow-400">Privacy Policy</a>
      </div>
    </div>

    <!-- Optional: keep FooterInfo OR delete it (see note below) -->
    <FooterInfo />
  </div>
</footer>
