<!-- MAP --><!-- MAP SECTION - LAZY LOADED VERSION (Cost-Saving) -->
<style>
  /* Map Section Styles - Using unique class names to avoid conflicts */
  .llk9-map-section {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40px 20px;
    background: #f5f5f5;
  }

  .llk9-map-wrapper {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
  }

  .llk9-map-container {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    margin: 0 auto;
    position: relative;
  }

  #llk9-map {
    width: 100%;
    height: 500px;
    display: block;
  }

  /* Placeholder styles before map loads */
  .llk9-map-placeholder {
    width: 100%;
    height: 500px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #e0e7ff 0%, #f3f4f6 100%);
    color: #4b5563;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .llk9-map-placeholder:hover {
    background: linear-gradient(135deg, #dbeafe 0%, #e5e7eb 100%);
  }

  .llk9-map-placeholder.loading {
    cursor: wait;
  }

  .llk9-spinner {
    border: 4px solid #e5e7eb;
    border-top: 4px solid #10b981;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    animation: spin 1s linear infinite;
    margin-bottom: 16px;
  }

  @keyframes spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 768px) {
    #llk9-map,
    .llk9-map-placeholder {
      height: 350px;
    }

    .llk9-map-section {
      padding: 20px 10px;
    }
  }
</style>

<!-- Map HTML -->
<div class="llk9-map-section">
  <div class="llk9-map-wrapper">
    <div class="llk9-map-container">
      <!-- Placeholder shown before map loads -->
      <div id="llk9-map-placeholder" class="llk9-map-placeholder">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-16 h-16 mb-4 text-emerald-600"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
          ></path>
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <p class="text-lg font-semibold mb-2">📍 Find Us in Bassett, VA</p>
        <p class="text-sm text-gray-600">Click or scroll to load map</p>
      </div>

      <!-- Actual map container (hidden until loaded) -->
      <div id="llk9-map" style="display: none;"></div>
    </div>
  </div>
</div>

<!-- Map JavaScript - LAZY LOADED -->
<script>
  (function () {
    let llk9Map;
    let llk9DirectionsService;
    let llk9DirectionsRenderer;
    let mapLoaded = false;
    let apiLoaded = false;

    // Exact coordinates for Leash Legacy K9 Training
    const leashLegacyLocation = {
      lat: 36.79920628344291,
      lng: -79.95534574528429,
    };

    // Function to load Google Maps API
    function loadGoogleMapsAPI() {
      if (apiLoaded) return Promise.resolve();

      return new Promise((resolve, reject) => {
        // Check if already loaded
        if (window.google && window.google.maps) {
          apiLoaded = true;
          resolve();
          return;
        }

        // Create script tag
        const script = document.createElement("script");
        script.src =
          "https://maps.googleapis.com/maps/api/js?key=AIzaSyBueQF46IjLec9OC_qjbk6AEWcCO91-yqU&callback=initLLK9Map";
        script.async = true;
        script.defer = true;

        script.onerror = () => reject(new Error("Failed to load Google Maps"));

        // Add to page
        document.head.appendChild(script);

        // Callback when API loads
        window.initLLK9Map = function () {
          apiLoaded = true;
          resolve();
        };
      });
    }

    // Function to initialize the map
    function initializeMap() {
      if (mapLoaded) return;

      const mapElement = document.getElementById("llk9-map");
      const placeholder = document.getElementById("llk9-map-placeholder");

      if (!mapElement || !window.google || !window.google.maps) return;

      // Initialize the map
      llk9Map = new google.maps.Map(mapElement, {
        zoom: 15,
        center: leashLegacyLocation,
        mapTypeControl: true,
        streetViewControl: true,
        fullscreenControl: true,
      });

      // Add marker
      const marker = new google.maps.Marker({
        position: leashLegacyLocation,
        map: llk9Map,
        title: "Leash Legacy K9 Training",
        animation: google.maps.Animation.DROP,
        icon: {
          url: "https://maps.google.com/mapfiles/ms/icons/green-dot.png",
        },
      });

      // Add info window
      const infoWindow = new google.maps.InfoWindow({
        content: `
                <div style="padding: 10px;">
                    <h3 style="margin: 0 0 10px 0; color: #2c5f2d;">Leash Legacy K9 Training</h3>
                    <p style="margin: 5px 0;"><strong>Professional Dog Training</strong></p>
                    <p style="margin: 5px 0;">Bassett, VA</p>
                    <a href="https://www.google.com/maps/dir/?api=1&destination=36.79920628344291,-79.95534574528429" 
                       target="_blank"
                       style="color: #2c5f2d; text-decoration: none; font-weight: bold;">
                       Get Directions →
                    </a>
                </div>
            `,
      });

      marker.addListener("click", () => {
        infoWindow.open(llk9Map, marker);
      });

      // Initialize directions service
      llk9DirectionsService = new google.maps.DirectionsService();
      llk9DirectionsRenderer = new google.maps.DirectionsRenderer({
        map: llk9Map,
        suppressMarkers: false,
        polylineOptions: {
          strokeColor: "#2c5f2d",
          strokeWeight: 5,
        },
      });

      // Hide placeholder, show map
      if (placeholder) placeholder.style.display = "none";
      mapElement.style.display = "block";

      mapLoaded = true;

      // Track map load in analytics
      if (window.dataLayer) {
        window.dataLayer.push({
          event: "map_loaded",
          map_location: "footer",
        });
      }
    }

    // Function to load the map when triggered
    function loadMap() {
      const placeholder = document.getElementById("llk9-map-placeholder");

      // Show loading state
      if (placeholder) {
        placeholder.classList.add("loading");
        placeholder.innerHTML = `
                <div class="llk9-spinner"></div>
                <p class="text-sm text-gray-600">Loading map...</p>
            `;
      }

      // Load API and initialize map
      loadGoogleMapsAPI()
        .then(() => initializeMap())
        .catch((error) => {
          console.error("Map loading error:", error);
          if (placeholder) {
            placeholder.innerHTML = `
                        <p class="text-red-600 font-semibold">⚠️ Unable to load map</p>
                        <a href="https://www.google.com/maps/dir/?api=1&destination=36.79920628344291,-79.95534574528429" 
                           target="_blank"
                           class="mt-2 text-emerald-600 underline">
                           Get Directions on Google Maps
                        </a>
                    `;
          }
        });
    }

    // Intersection Observer - Load when map section is visible
    const mapSection = document.querySelector(".llk9-map-section");

    if (mapSection && "IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !mapLoaded) {
              loadMap();
              observer.disconnect(); // Stop observing once loaded
            }
          });
        },
        {
          rootMargin: "100px", // Start loading 100px before it comes into view
        },
      );

      observer.observe(mapSection);
    }

    // Fallback: Click to load
    const placeholder = document.getElementById("llk9-map-placeholder");
    if (placeholder) {
      placeholder.addEventListener("click", () => {
        if (!mapLoaded) loadMap();
      });
    }

    // Optional: Expose function to get directions (if you want to add a button elsewhere)
    window.getLLK9Directions = function () {
      if (!mapLoaded) {
        loadMap();
        return;
      }

      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
          (position) => {
            const userLocation = {
              lat: position.coords.latitude,
              lng: position.coords.longitude,
            };

            llk9DirectionsService.route(
              {
                origin: userLocation,
                destination: leashLegacyLocation,
                travelMode: google.maps.TravelMode.DRIVING,
              },
              (response, status) => {
                if (status === "OK") {
                  llk9DirectionsRenderer.setDirections(response);

                  // Track in analytics
                  if (window.dataLayer) {
                    window.dataLayer.push({
                      event: "map_directions_requested",
                      location: "footer_map",
                    });
                  }
                } else {
                  console.error("Directions request failed: " + status);
                }
              },
            );
          },
          () => {
            alert("Could not get your location. Opening Google Maps instead.");
            window.open(
              "https://www.google.com/maps/dir/?api=1&destination=36.79920628344291,-79.95534574528429",
              "_blank",
            );
          },
        );
      } else {
        window.open(
          "https://www.google.com/maps/dir/?api=1&destination=36.79920628344291,-79.95534574528429",
          "_blank",
        );
      }
    };
  })();
</script>
