---

---

<!-- INFO Bar -->
<div class="w-full bg-yellow-500 text-white text-sm font-medium py-2 px-4">
  <div
    class="max-w-6xl mx-auto flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between"
  >
    <!-- Phone CTA + Socials -->
    <div class="flex items-center justify-center sm:justify-start gap-3">
      <a
        href="tel:2762292625"
        class="inline-flex items-center gap-2 bg-white text-yellow-700 font-semibold px-4 py-1.5 rounded-full shadow-sm hover:bg-yellow-100 transition"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l1.98-1.98a1.5 1.5 0 0 1 1.54-.36c1.68.55 3.49.85 5.27.85.83 0 1.5.67 1.5 1.5V21a1.5 1.5 0 0 1-1.5 1.5C10.3 22.5 1.5 13.7 1.5 3A1.5 1.5 0 0 1 3 1.5h2.61c.83 0 1.5.67 1.5 1.5 0 1.78.3 3.59.85 5.27.15.52.02 1.08-.36 1.54l-1.98 1.98Z"
          ></path>
        </svg>
        <span>Call: (276) 229-2625</span>
      </a>

      <!-- Social Icons -->
      <div class="flex items-center gap-2">
        <!-- YouTube -->
        <a
          href="https://youtube.com/@leashlegacyk9"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-white hover:bg-white/90 transition"
          aria-label="YouTube"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="w-4 h-4"
            fill="#FF0000"
          >
            <path
              d="M21.6 7.2a3.02 3.02 0 0 0-2.12-2.13C17.9 4.6 12 4.6 12 4.6s-5.9 0-7.48.47A3.02 3.02 0 0 0 2.4 7.2 31.3 31.3 0 0 0 2 12a31.3 31.3 0 0 0 .4 4.8 3.02 3.02 0 0 0 2.12 2.13C6.1 19.4 12 19.4 12 19.4s5.9 0 7.48-.47a3.02 3.02 0 0 0 2.12-2.13A31.3 31.3 0 0 0 22 12a31.3 31.3 0 0 0-.4-4.8zM10 15.5v-7l6 3.5-6 3.5z"
            ></path>
          </svg>
        </a>

        <!-- Instagram -->
        <a
          href="https://instagram.com/leashlegacyk9"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-white hover:bg-white/90 transition"
          aria-label="Instagram"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#E1306C"
            stroke-width="2"
          >
            <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
            <circle cx="12" cy="12" r="3.5"></circle>
            <circle cx="17.2" cy="6.8" r="1"></circle>
          </svg>
        </a>

        <!-- Facebook -->
        <a
          href="https://facebook.com/leashlegacyk9"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-white hover:bg-white/90 transition"
          aria-label="Facebook"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#1877F2"
            stroke-width="2"
          >
            <path
              d="M18 2h-2.5A4.5 4.5 0 0 0 11 6.5V9H9v4h2v8h4v-8h2.9l.6-4H15V6.6c0-.35.28-.63.63-.63H18V2z"
            ></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Certification Trust Badge (RIGHT SIDE) -->
    <div class="flex items-center justify-center sm:justify-end gap-3">
      <a
        href="/certifications"
        class="inline-flex items-center gap-2 text-white/95 hover:text-white transition text-xs sm:text-sm font-semibold"
        title="View Trainer Certifications"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M12 2 4 5v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V5l-8-3z"
          ></path>
        </svg>
        <span>Certified Trainer</span>
      </a>

      <span class="hidden sm:inline text-black/100 text-xs">
        Ethical • Real-World • Results-Driven
      </span>
    </div>
  </div>
</div>
