---
import BrandTitle from "../components/app/BrandTitle.vue";
---

<header class="bg-white/95 backdrop-blur shadow-md sticky top-0 z-50">
  <div
    class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between px-4 py-4 gap-4"
  >
    <div class="flex items-center gap-3">
      <a href="https://leashlegacyk9.com/" class="hover:opacity-90 transition">
        <img
          src="https://leashlegacyk9.com/imgs/leashlegacyk9.webp"
          alt="Professional dog training services specializing in board & train programs, behavior modification, and reactivity rehabilitation in Bassett, VA."
          class="w-10 h-auto"
        />
      </a>

      <BrandTitle client:load />

      <!-- Mobile Toggle -->
      <button
        id="nav-toggle"
        class="md:hidden p-2 rounded-lg border border-gray-200 hover:border-yellow-500 text-gray-700"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Open menu"
      >
        <!-- simple hamburger -->
        <span class="block w-6 h-0.5 bg-gray-800 mb-1"></span>
        <span class="block w-6 h-0.5 bg-gray-800 mb-1"></span>
        <span class="block w-6 h-0.5 bg-gray-800"></span>
      </button>

      <!-- Desktop Nav -->
      <nav
        id="nav-menu"
        class="hidden flex-col gap-3 lg:gap-1 md:flex md:flex-row md:space-x-6 text-lg uppercase font-medium w-full md:w-auto"
      >
        <a
          href="https://leashlegacyk9.com/"
          class="text-gray-800 hover:text-yellow-500 transition">Home</a
        >
        <a
          href="https://leashlegacyk9.com/#programs"
          class="text-gray-800 hover:text-yellow-500 transition">Services</a
        >
        <a
          href="https://leashlegacyk9.com/#faq"
          class="text-gray-800 hover:text-yellow-500 transition">FAQ</a
        >
        <a
          href="https://leashlegacyk9.com/contact/"
          class="text-gray-800 hover:text-yellow-500 transition">Contact</a
        >

        <!-- Philosophy -->
        <div class="relative group">
          <button
            class="text-gray-800 hover:text-yellow-500 transition focus:outline-none"
            >ABOUT</button
          >
          <div
            class="absolute left-0 mt-2 w-56 bg-white border border-gray-200 rounded-md shadow-lg z-50 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200"
          >
            <a
              href="https://leashlegacyk9.com/#certifications"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
              >Certifications</a
            >

            <a
              href="https://leashlegacyk9.com/#philosophy"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
              >Philosophy</a
            >
            <a
              href="https://leashlegacyk9.com/#mission-about"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
              >ABOUT US</a
            >
            <a
              href="https://leashlegacyk9.com/#why-leash-legacy"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
              >WHY US</a
            >
            <a
              href="https://leashlegacyk9.com/#llk9-map"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
              >MAP</a
            >
          </div>
        </div>
        <!-- RESOURCES -->
        <div class="relative group">
          <button
            class="text-gray-800 hover:text-yellow-500 transition focus:outline-none"
          >
            RESOURCES
          </button>

          <div
            class="absolute left-0 mt-2 w-64 bg-white border border-gray-200 rounded-md shadow-lg z-50
           opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200"
          >
            <!-- Guides submenu wrapper -->
            <div class="relative group/guides">
              <div
                class="flex items-center justify-between px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100 cursor-pointer"
              >
                <span>Guides</span>
                <svg
                  class="w-4 h-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M9 5l7 7-7 7"></path>
                </svg>
              </div>

              <!-- Submenu (flies out to the right) -->
              <div
                class="absolute top-0 left-full ml-2 w-64 bg-white border border-gray-200 rounded-md shadow-lg
               opacity-0 invisible group-hover/guides:opacity-100 group-hover/guides:visible transition-all duration-200"
              >
                <a
                  href="https://leashlegacyk9.com/desensitize.html"
                  class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
                >
                  Desensitization
                </a>

                <a
                  href="https://leashlegacyk9.com/nailclipping.html"
                  class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
                >
                  Nail Clipping
                </a>

                <!-- Optional future-proof slots (safe to leave) -->
                <a
                  href="https://leashlegacyk9.com/puppy/"
                  class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
                >
                  Puppy Guide
                </a>
                <a
                  href="https://leashlegacyk9.com/reactive-dog-guide/"
                  class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
                >
                  Reactive Dog Guide
                </a>
              </div>
            </div>

            <!-- Main resources -->
            <a
              href="https://leashlegacyk9.com/newsletter/"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
            >
              Newsletter
            </a>

            <!-- Optional: better bucket for PDFs/checklists later -->
            <a
              href="https://leashlegacyk9.com/resources/"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
            >
              Downloads
            </a>
          </div>
        </div>

        <!-- LOCATIONS REMOVED VISUALLY; LINKS KEPT FOR SEO -->
        <!-- <div class="sr-only" id="locations-linklist" aria-hidden="false">
        <a href="https://leashlegacyk9.com/collinsville/">Collinsville, VA</a>
        <a href="https://leashlegacyk9.com/martinsville/">Martinsville, VA</a>
        <a href="https://leashlegacyk9.com/rocky-mount/">Rocky Mount, VA</a>
        <a href="https://leashlegacyk9.com/boones-mill/">Boones Mill, VA</a>
        <a href="https://leashlegacyk9.com/roanoke/">Roanoke, VA</a>
      </div> -->

        <!-- PROGRAMS -->
        <div class="relative group">
          <button
            class="text-gray-800 hover:text-yellow-500 transition focus:outline-none"
            >PROGRAMS</button
          >
          <div
            class="absolute left-0 mt-2 w-64 bg-white border border-gray-200 rounded-md shadow-lg z-50 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200"
          >
            <a
              href="https://leashlegacyk9.com/programs/handlers-course/"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
              >HANDLERS COURSE</a
            >
            <a
              href="https://leashlegacyk9.com/programs/puppy/"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
              >PUPPY BOOTCAMP (Calm Foundations)</a
            >
            <a
              href="https://leashlegacyk9.com/programs/5-day-bootcamp/"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
              >5 DAY BOOTCAMP (Behavioral Foundations)</a
            >
            <a
              href="https://leashlegacyk9.com/programs/off-leash/"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
              >OFF-LEASH</a
            >
            <!-- <a
              href="https://leashlegacyk9.com/programs/6-week-intensive/"
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-yellow-100"
              >6 WEEK INTENSIVE (Behavioral Rehabilitation)</a -->
          </div>
        </div>
      </nav>
    </div>
  </div>
</header>
