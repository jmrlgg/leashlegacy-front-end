---
/**
 * ProgramsSection.astro
 * Reusable pricing/programs block (static, no JS)
 *
 * Optional props:
 * - id: section id (default "pricing")
 * - heading: main heading text
 */
const {
  id = "pricing",
  eyebrow = "Pricing & Programs",
  title = "Find Your Dog's Path",
  subtitle = "Results-driven training built for your lifestyle. Select a program to start your transformation.",
} = Astro.props;
---

<section id={id} class="py-16 bg-gray-50 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-green-600 font-semibold uppercase tracking-wider mb-2">
        {eyebrow}
      </p>
      <h2 class="text-3xl md:text-5xl font-extrabold text-gray-900 uppercase">
        {title}
      </h2>
      <p class="text-gray-600 mt-4 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Kickstarter Program -->
      <div
        class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden flex flex-col transition hover:shadow-2xl"
      >
        <div class="p-6 border-b border-gray-100">
          <h3 class="text-xl font-bold text-gray-900 uppercase">
            3–5 Day Kickstarter
          </h3>
          <p class="text-sm text-gray-500 mt-1">Foundational Reset</p>
          <div class="mt-4 text-3xl font-black text-gray-900">$900</div>
        </div>

        <div class="p-6 flex-grow">
          <ul class="space-y-4 text-sm text-gray-700">
            <li class="flex items-center gap-2">
              ✅ <strong>Best For:</strong> Leash manners & focus
            </li>
            <li class="flex items-center gap-2">
              ✅ <strong>Format:</strong> Daily Drop-off or Board & Train
            </li>
            <li class="flex items-center gap-2">
              ✅ <strong>Goal:</strong> Stop pulling & jumping
            </li>
            <li class="flex items-center gap-2 text-gray-400">
              ❌ Off-leash reliability
            </li>
          </ul>

          <div class="mt-6 pt-6 border-t border-gray-100">
            <a
              href="https://leashlegacyk9.com/programs/3-5-kickstarter/"
              class="flex items-center justify-center gap-2 text-green-600 font-semibold text-sm hover:text-green-700 transition group"
            >
              <span>View Program Details</span>
              <svg
                class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="p-6 bg-gray-50">
          <a
            href="https://leashlegacyk9.com/contact/l?usp=header&utm_source=website&utm_medium=form-signup&utm_campaign=signature_programs&utm_id=kickstarter-program"
            class="block w-full text-center py-3 bg-gray-800 text-white font-bold rounded-lg uppercase hover:bg-black transition"
          >
            Apply Now
          </a>
        </div>
      </div>

      <!-- Signature Board & Train (Recommended) -->
      <div
        class="bg-white rounded-2xl shadow-2xl border-2 border-emerald-500 overflow-hidden flex flex-col relative scale-105 z-10"
      >
        <div
          class="absolute top-0 right-0 bg-emerald-500 text-white text-[10px] font-bold px-3 py-1 uppercase tracking-widest"
        >
          Recommended
        </div>

        <div class="p-6 border-b border-emerald-100 bg-emerald-50/50">
          <h3 class="text-xl font-bold text-gray-900 uppercase">
            Signature Board & Train
          </h3>
          <p class="text-sm text-emerald-700 mt-1">
            Full Behavioral Reset 4+ Weeks
          </p>
          <div class="mt-4 text-4xl font-black text-emerald-600">$2,750+</div>
        </div>

        <div class="p-6 flex-grow">
          <ul class="space-y-4 text-sm text-gray-700">
            <li class="flex items-center gap-2">
              ✅ <strong>Best For:</strong> Reactivity & Aggression
            </li>
            <li class="flex items-center gap-2">
              ✅ <strong>Format:</strong> Full-time Live-in
            </li>
            <li class="flex items-center gap-2">
              ✅ <strong>Goal:</strong> Off-leash freedom & stability
            </li>
            <li class="flex items-center gap-2">
              ✅ <strong>Support:</strong> Lifetime Handler Support
            </li>
          </ul>

          <div class="mt-6 pt-6 border-t border-emerald-100">
            <a
              href="https://leashlegacyk9.com/programs/off-leash/"
              class="flex items-center justify-center gap-2 text-emerald-600 font-semibold text-sm hover:text-emerald-700 transition group"
            >
              <span>View Program Details</span>
              <svg
                class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="p-6 bg-emerald-50">
          <a
            href="https://leashlegacyk9.com/contact/l?usp=header&utm_source=website&utm_medium=form-signup&utm_campaign=signature_programs&utm_id=offleash-program"
            class="block w-full text-center py-4 bg-emerald-600 text-white font-bold rounded-lg uppercase hover:bg-emerald-700 shadow-lg transition"
          >
            Start The Reset
          </a>
        </div>
      </div>

      <!-- Puppy Starter Program -->
      <div
        class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden flex flex-col transition hover:shadow-2xl"
      >
        <div class="p-6 border-b border-gray-100">
          <h3 class="text-xl font-bold text-gray-900 uppercase">
            Puppy Starter
          </h3>
          <p class="text-sm text-gray-500 mt-1">3-Week Live-in Immersion</p>
          <div class="mt-4 text-3xl font-black text-gray-900">$1,900</div>
        </div>

        <div class="p-6 flex-grow">
          <ul class="space-y-4 text-sm text-gray-700">
            <li class="flex items-center gap-2">
              ✅ <strong>Best For:</strong> Pups under 9 months
            </li>
            <li class="flex items-center gap-2">
              ✅ <strong>Focus:</strong> Socialization & Crate
            </li>
            <li class="flex items-center gap-2">
              ✅ <strong>Support:</strong> 2 Handler Coaching Sessions
            </li>
            <li class="flex items-center gap-2">
              ✅ <strong>Goal:</strong> Lifelong foundation
            </li>
          </ul>

          <div class="mt-6 pt-6 border-t border-gray-100">
            <a
              href="https://leashlegacyk9.com/programs/puppy-starter/"
              class="flex items-center justify-center gap-2 text-green-600 font-semibold text-sm hover:text-green-700 transition group"
            >
              <span>View Program Details</span>
              <svg
                class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="p-6 bg-gray-50">
          <a
            href="https://leashlegacyk9.com/contact/l?usp=header&utm_source=website&utm_medium=form-signup&utm_campaign=signature_programs&utm_id=puppy--program"
            class="block w-full text-center py-3 bg-gray-800 text-white font-bold rounded-lg uppercase hover:bg-black transition"
          >
            Book Puppy Start
          </a>
        </div>
      </div>
    </div>

    <div
      class="mt-12 text-center text-xs text-gray-500 max-w-xl mx-auto italic"
    >
      *Final investment is determined following your mandatory consultation.
      Program costs include all primary tools, though specialized gear and taxes
      may be extra.
    </div>
  </div>
</section>
